{
  "manifest_version": 3,
  "name": "Spiel",
  "version": "1.1.0",
  "description": "Listen to any article, blog post, or selection. Local AI voice — private, free, no cloud, no subscription.",
  "permissions": ["activeTab", "scripting", "storage", "alarms", "offscreen"],
  "host_permissions": ["http://127.0.0.1:8880/*", "http://localhost:8880/*", "file:///*"],
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.min.mjs"],
      "matches": ["http://*/*", "https://*/*", "file:///*"]
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
